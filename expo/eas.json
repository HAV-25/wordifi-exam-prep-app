      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_REVENUECAT_ANDROID_KEY": "goog_sLePzbKxQdzAQwFkIfWdQajwxVh"
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_REVENUECAT_ANDROID_KEY": "goog_sLePzbKxQdzAQwFkIfWdQajwxVh"
